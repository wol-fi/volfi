#!/bin/sh
set -e
url="https://raw.githubusercontent.com/wol-fi/volfi/main/include/volfi/volfi.hpp"
if command -v curl >/dev/null 2>&1; then
  curl -L "$url" -o src/volfi.hpp
elif command -v wget >/dev/null 2>&1; then
  wget -O src/volfi.hpp "$url"
else
  echo "curl or wget is required to fetch volfi.hpp" >&2
  exit 1
fi
